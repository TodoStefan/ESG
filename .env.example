# Trage hier deine Supabase-Projektdaten ein (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Wichtig: nur den anon/public key im Frontend verwenden (nie service_role)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Alternative Bezeichnung aus neuerer Supabase-Doku (ebenfalls unterstützt)
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
